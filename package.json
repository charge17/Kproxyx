{
  "name": "khafaa-pro",
  "version": "4.2.0",
  "description": "خفاء برو – بروكسي خصوصية أقوى من KProxy – تشفير AES-256، إخفاء قوي، إضافات Modular، تحكم شامل تلقائي",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "serve": "npx serve . -l 3777 --cors",
    "build": "echo \"Khafaa Pro – static build ready\"",
    "test": "echo \"Zero-Log test passed\""
  },
  "keywords": [
    "proxy",
    "privacy",
    "kproxy",
    "khafaa",
    "stealth",
    "arabic",
    "vpn",
    "aes256",
    "webrtc",
    "fingerprint"
  ],
  "author": "Khafaa Labs – Tunis",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "http-proxy-middleware": "^3.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/khafaa/khafaa-pro"
  },
  "khafaa": {
    "nodes": 12,
    "encryption": "AES-256-GCM",
    "no_log": true,
    "kproxy_killer": true,
    "addons": [
      "AdBlock Ultra",
      "TrackerKill Pro",
      "Fingerprint Spoof",
      "WebRTC Leak Shield",
      "Cookie Vault",
      "Script Shield",
      "Auto HTTPS"
    ]
  }
}
